  "keyFeatures": [
    "Data Grid with sorting, filtering, pagination, editing, and virtualization",
    "Date and Time Pickers with multiple adapters (Day.js, Luxon, Moment, date-fns)",
    "Charts: Bar, Line, Pie, Scatter, Radar, Gauge, and Sparkline",
    "Tree View with drag-and-drop and rich customization",
    "Community (MIT), Pro, and Premium licensing tiers",
    "Full TypeScript support with comprehensive type definitions",
    "Theming and slots API for deep customization",
    "Server-side data support with lazy loading and infinite scroll",
    "Excel and CSV export for Data Grid",
    "Row grouping, aggregation, and pivoting (Premium)"
  ],
  "publicApiSurface": [
    "DataGrid (@mui/x-data-grid)",
    "DataGridPro (@mui/x-data-grid-pro)",
    "DataGridPremium (@mui/x-data-grid-premium)",
    "DatePicker (@mui/x-date-pickers)",
